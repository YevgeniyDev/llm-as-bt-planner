# Template only: the program loads values from `.env` and existing shell env vars.
LLM_PROVIDER=huggingface
HF_TOKEN=your_huggingface_token_here
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
PLANNING_SCHEME=scheme4
ENABLE_HUMAN_IN_THE_LOOP=false
MAX_REVIEW_ROUNDS=3
MAX_RECURSION_DEPTH=3
MAX_SUBGOALS_PER_LEVEL=4
ENABLE_MULTI_ROBOT=true
MULTI_ROBOT_ROBOTS=[{"name":"robot1","capabilities":["Pick","MoveTo","Place","Insert","ChangeTool","Handoff"],"available_tools":["default_gripper"],"priority":0},{"name":"robot2","capabilities":["Pick","MoveTo","Place","Insert","ChangeTool","Handoff"],"available_tools":["default_gripper","precision_gripper"],"priority":1}]

# Optional OpenAI fallback
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
